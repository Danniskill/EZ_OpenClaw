{
  "name": "ez-openclaw",
  "version": "1.0.0",
  "description": "EZ Installer & Manager for OpenClaw using Windows 11 Settings UI Style",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "vite build",
    "dist": "npm run build:renderer && electron-builder"
  },
  "keywords": [
    "openclaw",
    "gui",
    "installer",
    "windows11"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "i18next": "^23.11.5",
    "json5": "^2.2.3",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "systeminformation": "^5.22.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ezopenclaw.app",
    "productName": "EZ-OpenClaw",
    "directories": {
      "output": "dist-package"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "YOUR_GITHUB_REPO"
      }
    ],
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EZ-OpenClaw"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "esbuild@0.21.5": true
  }
}
